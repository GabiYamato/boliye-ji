# ── LLM Provider ─────────────────────────────────────────────────────
LLM_PROVIDER=auto
# "gemini" = Google Gemini (cloud), "ollama" = local Ollama, "auto" = try gemini first
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Ollama fallback (only used if LLM_PROVIDER=ollama or gemini is unavailable)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Vector DB ────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=boliye_local
QDRANT_EMBED_DIM=768

# ── TTS Provider ─────────────────────────────────────────────────────
TTS_PROVIDER=auto
# "qwen" = Qwen3-TTS (local server), "hf" = HuggingFace VITS, "auto" = try qwen first
TTS_QWEN_BASE_URL=http://localhost:8880
TTS_QWEN_MODEL=qwen3-tts
TTS_QWEN_API_KEY=
TTS_QWEN_VOICE=Vivian
TTS_HF_MODEL=facebook/mms-tts-eng
TTS_DEVICE=auto

# ── STT ──────────────────────────────────────────────────────────────
WHISPER_MODEL=base
STT_BACKEND=whisper

# ── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me
GOOGLE_CLIENT_ID=
FRONTEND_ORIGIN=http://localhost:5173

# ── Frontend (.env in frontend/) ─────────────────────────────────────
# VITE_GOOGLE_CLIENT_ID=
# VITE_API_URL=
